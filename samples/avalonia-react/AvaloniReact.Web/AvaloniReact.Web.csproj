<Project Sdk="Microsoft.Build.NoTargets/3.7.134">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <None Include="src\**\*" Exclude="src\bridge\generated\**" />
    <None Include="package.json" />
    <None Include="vite.config.ts" />
    <None Include="tsconfig.json" />
    <None Include="index.html" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Update="MinVer" Version="8.0.0-alpha.1" />
  </ItemGroup>

  <Target Name="NpmInstall"
          BeforeTargets="Build"
          Inputs="package.json"
          Outputs="node_modules/.install-stamp">
    <Exec Command="npm ci" />
    <Touch Files="node_modules/.install-stamp" AlwaysCreate="true" />
  </Target>

  <Target Name="WebBuild"
          DependsOnTargets="NpmInstall"
          AfterTargets="Build"
          Condition="'$(Configuration)' == 'Release'"
          Inputs="src/**/*;package.json;vite.config.ts;tsconfig.json"
          Outputs="dist/.build-stamp">
    <Exec Command="npm run build" />
    <Touch Files="dist/.build-stamp" AlwaysCreate="true" />
  </Target>

</Project>
