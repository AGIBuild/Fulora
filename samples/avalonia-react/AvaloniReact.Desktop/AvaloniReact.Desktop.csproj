<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <BuiltInComInteropSupport>true</BuiltInComInteropSupport>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <RootNamespace>AvaloniReact.Desktop</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" Version="12.0.0-preview1" />
    <PackageReference Include="Avalonia.Desktop" Version="12.0.0-preview1" />
    <PackageReference Include="Avalonia.Themes.Fluent" Version="12.0.0-preview1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\src\Agibuild.Fulora.Avalonia\Agibuild.Fulora.Avalonia.csproj" />
    <ProjectReference Include="..\..\..\src\Agibuild.Fulora.Runtime\Agibuild.Fulora.Runtime.csproj" />
    <ProjectReference Include="..\..\..\src\Agibuild.Fulora.Adapters.Windows\Agibuild.Fulora.Adapters.Windows.csproj" Condition="$([MSBuild]::IsOSPlatform('Windows'))" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\AvaloniReact.Bridge\AvaloniReact.Bridge.csproj" />
  </ItemGroup>

  <!-- Release: build React app and embed as resources -->
  <Target Name="BuildWebApp" BeforeTargets="BeforeBuild" Condition="'$(Configuration)' == 'Release'">
    <Exec Command="npm run build" WorkingDirectory="../AvaloniReact.Web" />
  </Target>

  <ItemGroup Condition="'$(Configuration)' == 'Release'">
    <EmbeddedResource Include="..\AvaloniReact.Web\dist\**\*" LinkBase="wwwroot" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Update="MinVer" Version="8.0.0-alpha.1" />
  </ItemGroup>

  <ItemGroup Condition="$([MSBuild]::IsOSPlatform('OSX'))">
    <ProjectReference Include="..\..\..\src\Agibuild.Fulora.Adapters.MacOS\Agibuild.Fulora.Adapters.MacOS.csproj" />
  </ItemGroup>
  <ItemGroup Condition="$([MSBuild]::IsOSPlatform('Linux'))">
    <ProjectReference Include="..\..\..\src\Agibuild.Fulora.Adapters.Gtk\Agibuild.Fulora.Adapters.Gtk.csproj" />
  </ItemGroup>

  <Target Name="CopyMacOSNativeShim" AfterTargets="Build"
          Condition="$([MSBuild]::IsOSPlatform('osx'))">
    <ItemGroup>
      <_MacShim Include="..\..\..\src\Agibuild.Fulora.Adapters.MacOS\bin\$(Configuration)\net10.0\runtimes\osx\native\libAgibuildWebViewWk.dylib" />
    </ItemGroup>
    <MakeDir Directories="$(OutDir)runtimes/osx/native/" />
    <Copy SourceFiles="@(_MacShim)" DestinationFolder="$(OutDir)runtimes/osx/native/" SkipUnchangedFiles="true" />
  </Target>

  <Target Name="CopyLinuxNativeShim" AfterTargets="Build"
          Condition="$([MSBuild]::IsOSPlatform('linux'))">
    <ItemGroup>
      <_GtkShim Include="..\..\..\src\Agibuild.Fulora.Adapters.Gtk\bin\$(Configuration)\net10.0\runtimes\linux-x64\native\libAgibuildWebViewGtk.so" />
    </ItemGroup>
    <MakeDir Directories="$(OutDir)runtimes/linux-x64/native/" />
    <Copy SourceFiles="@(_GtkShim)" DestinationFolder="$(OutDir)runtimes/linux-x64/native/" SkipUnchangedFiles="true" />
  </Target>

</Project>
