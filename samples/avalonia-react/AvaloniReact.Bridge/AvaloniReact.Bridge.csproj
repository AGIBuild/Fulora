<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>AvaloniReact.Bridge</RootNamespace>
    <RestoreAdditionalProjectSources>$(RestoreAdditionalProjectSources);$(MSBuildThisFileDirectory)..\..\..\artifacts\packages</RestoreAdditionalProjectSources>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Agibuild.Fulora.Core" />
  </ItemGroup>

  <PropertyGroup>
    <BridgeTypeScriptOutputDir>$(MSBuildProjectDirectory)\..\AvaloniReact.Web\src\bridge\generated</BridgeTypeScriptOutputDir>
  </PropertyGroup>

  <!-- Source generator for typed bridge (AOT-safe proxies; falls back to reflection when absent) -->
  <ItemGroup>
    <PackageReference Include="Agibuild.Fulora.Bridge.Generator" OutputItemType="Analyzer" ReferenceOutputAssembly="false" PrivateAssets="all" />
  </ItemGroup>
  <ItemGroup>
  </ItemGroup>

</Project>
