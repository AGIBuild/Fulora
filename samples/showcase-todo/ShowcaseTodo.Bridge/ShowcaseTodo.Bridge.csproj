<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>ShowcaseTodo.Bridge</RootNamespace>
    <BridgeTypeScriptOutputDir>$(MSBuildProjectDirectory)\..\ShowcaseTodo.Web\src\bridge\generated</BridgeTypeScriptOutputDir>
    <RestoreAdditionalProjectSources>$(RestoreAdditionalProjectSources);$(MSBuildThisFileDirectory)..\..\..\artifacts\packages</RestoreAdditionalProjectSources>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Agibuild.Fulora.Core" Version="*-*" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Agibuild.Fulora.Bridge.Generator" Version="*-*" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
  </ItemGroup>

</Project>
