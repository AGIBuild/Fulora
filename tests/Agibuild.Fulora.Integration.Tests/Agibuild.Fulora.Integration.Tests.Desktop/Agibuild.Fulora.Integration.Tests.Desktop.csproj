<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <!--If you are willing to use platform-specific APIs, use conditional compilation.
    See https://docs.avaloniaui.net/docs/guides/platforms/platform-specific-code/dotnet for more details.-->
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <PropertyGroup>
    <ApplicationManifest>app.manifest</ApplicationManifest>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia.Desktop" />
    <!-- Avalonia.Diagnostics not yet available for 12.x; re-enable when published
    <PackageReference Include="Avalonia.Diagnostics" >
      <IncludeAssets Condition="'$(Configuration)' != 'Debug'">None</IncludeAssets>
      <PrivateAssets Condition="'$(Configuration)' != 'Debug'">All</PrivateAssets>
    </PackageReference>
    -->
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Agibuild.Fulora.Integration.Tests\Agibuild.Fulora.Integration.Tests.csproj" />
  </ItemGroup>

  <!-- Unified desktop platforms assembly. The same DLL is needed on Windows/macOS/Linux smoke hosts
       so its ModuleInitializer registers the active-OS provider at runtime. -->
  <!-- Windows: use project reference so NuGet deps (WebView2) are in deps.json. -->
  <ItemGroup Condition="$([MSBuild]::IsOSPlatform('windows'))">
    <ProjectReference Include="..\..\..\src\Agibuild.Fulora.Platforms\Agibuild.Fulora.Platforms.csproj" />
  </ItemGroup>

  <!-- Linux: copy Platforms assembly + GTK native shim so the adapter auto-registers at runtime. -->
  <Target Name="CopyLinuxPlatformsAdapterForSmoke"
          AfterTargets="Build"
          Condition="$([MSBuild]::IsOSPlatform('linux'))">
    <ItemGroup>
      <_PlatformsAdapter Include="..\..\..\src\Agibuild.Fulora.Platforms\bin\$(Configuration)\net10.0\Agibuild.Fulora.Platforms.dll" />
      <_GtkShim Include="..\..\..\src\Agibuild.Fulora.Platforms\bin\$(Configuration)\net10.0\runtimes\linux-x64\native\libAgibuildWebViewGtk.so" />
    </ItemGroup>

    <Exec Command="dotnet build &quot;..\..\..\src\Agibuild.Fulora.Platforms\Agibuild.Fulora.Platforms.csproj&quot; -c $(Configuration)" />

    <Copy SourceFiles="@(_PlatformsAdapter)"
          DestinationFolder="$(OutDir)"
          SkipUnchangedFiles="true" />

    <MakeDir Directories="$(OutDir)runtimes/linux-x64/native/" />
    <Copy SourceFiles="@(_GtkShim)"
          DestinationFolder="$(OutDir)runtimes/linux-x64/native/"
          SkipUnchangedFiles="true" />
  </Target>

  <Target Name="CopyMacOSPlatformsAdapterForSmoke"
          AfterTargets="Build"
          Condition="$([MSBuild]::IsOSPlatform('osx'))">
    <ItemGroup>
      <_PlatformsAdapter Include="..\..\..\src\Agibuild.Fulora.Platforms\bin\$(Configuration)\net10.0\Agibuild.Fulora.Platforms.dll" />
      <_MacShim Include="..\..\..\src\Agibuild.Fulora.Platforms\bin\$(Configuration)\net10.0\runtimes\osx\native\libAgibuildWebViewWk.dylib" />
    </ItemGroup>

    <Exec Command="dotnet build &quot;..\..\..\src\Agibuild.Fulora.Platforms\Agibuild.Fulora.Platforms.csproj&quot; -c $(Configuration)" />

    <Copy SourceFiles="@(_PlatformsAdapter)"
          DestinationFolder="$(OutDir)"
          SkipUnchangedFiles="true" />

    <MakeDir Directories="$(OutDir)runtimes/osx/native/" />
    <Copy SourceFiles="@(_MacShim)"
          DestinationFolder="$(OutDir)runtimes/osx/native/"
          SkipUnchangedFiles="true" />
  </Target>
</Project>
