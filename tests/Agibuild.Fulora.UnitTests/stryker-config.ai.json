{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker-net/master/src/Stryker.Core/Stryker.Core/stryker-config.schema.json",
  "stryker-config": {
    "project": "Agibuild.Fulora.AI.csproj",
    "test-runner": "mtp",
    "test-case-filter": "FullyQualifiedName~Agibuild.Fulora.UnitTests.Ai",
    "mutate": [
      "**/AiBridgeService.cs",
      "**/InMemoryAiConversationManager.cs",
      "**/AiProviderRegistry.cs",
      "**/AiPayloadRouter.cs",
      "**/InMemoryAiPayloadStore.cs",
      "**/FuloraAiServiceCollectionExtensions.cs"
    ],
    "mutation-level": "Standard",
    "thresholds": {
      "high": 80,
      "low": 60,
      "break": 0
    },
    "reporters": [
      "cleartext",
      "progress",
      "json"
    ],
    "ignore-mutations": [
      "string",
      "linq"
    ],
    "concurrency": 4
  }
}
