{
  "id": "Agibuild.Fulora.Plugin.Database",
  "displayName": "Database",
  "services": ["DatabaseService"],
  "npmPackage": "@agibuild/fulora-plugin-database",
  "minFuloraVersion": "1.0.0",
  "platforms": ["windows", "macos", "linux", "android", "ios"],
  "requiredCapabilities": ["plugin.database.read", "plugin.database.write"],
  "optionalCapabilities": [],
  "securityNotes": [
    "Use parameterized SQL when forwarding untrusted input into database operations.",
    "Review database path, migrations, and backup handling before enabling production writes."
  ],
  "platformConstraints": ["desktop-hosts", "connection-options-required-for-production"]
}
