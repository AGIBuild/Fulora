{
  "id": "Agibuild.Fulora.Plugin.LocalStorage",
  "displayName": "Local Storage",
  "services": ["LocalStorageService"],
  "npmPackage": "@agibuild/bridge-plugin-localstorage",
  "minFuloraVersion": "1.0.0",
  "platforms": ["windows", "macos", "linux", "android", "ios"],
  "requiredCapabilities": ["plugin.localstorage.read", "plugin.localstorage.write"],
  "optionalCapabilities": [],
  "securityNotes": [
    "Local storage persists application data on disk and should not be used for secrets.",
    "Hosts should keep storage paths inside the application profile or another governed directory."
  ],
  "platformConstraints": ["desktop-hosts", "app-profile-scope"]
}
