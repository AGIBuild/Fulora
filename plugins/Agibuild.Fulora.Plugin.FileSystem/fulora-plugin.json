{
  "id": "Agibuild.Fulora.Plugin.FileSystem",
  "displayName": "File System",
  "services": ["FileSystemService"],
  "npmPackage": "@agibuild/fulora-plugin-filesystem",
  "minFuloraVersion": "1.0.0",
  "platforms": ["windows", "macos", "linux", "android", "ios"],
  "requiredCapabilities": ["plugin.filesystem.read", "plugin.filesystem.write"],
  "optionalCapabilities": ["plugin.filesystem.pick"],
  "securityNotes": [
    "Constrain access to sandboxed or policy-approved roots.",
    "Write operations remain gated by FileSystemOptions.AllowWrite."
  ],
  "platformConstraints": ["desktop-hosts", "sandbox-or-policy-governed-paths"]
}
