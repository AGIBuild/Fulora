<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <BridgeTypeScriptOutputDir Condition="Exists('$(MSBuildProjectDirectory)\..\HybridApp.Web\src\bridge')">$(MSBuildProjectDirectory)\..\HybridApp.Web\src\bridge\generated</BridgeTypeScriptOutputDir>
    <BridgeTypeScriptOutputDir Condition="'$(BridgeTypeScriptOutputDir)' == ''">$(MSBuildProjectDirectory)\..\HybridApp.Web\src\bridge\generated</BridgeTypeScriptOutputDir>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Agibuild.Fulora.Core" />
  </ItemGroup>

  <!-- Source generator for typed bridge -->
  <ItemGroup>
    <PackageReference Include="Agibuild.Fulora.Bridge.Generator"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false"
                      PrivateAssets="all" />
  </ItemGroup>

</Project>
