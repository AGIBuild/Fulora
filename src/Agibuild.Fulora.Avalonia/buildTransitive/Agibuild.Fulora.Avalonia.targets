<Project>
  <PropertyGroup>
    <!--
      WebView2 dependency resolution:
      - This package ships the Windows adapter assembly, which depends on Microsoft.Web.WebView2.Core at runtime.
      - Microsoft.Web.WebView2 does not reliably flow compile references transitively without its build targets.
      - To keep host projects free from WebView2 build/buildTransitive injection while still ensuring the required
        runtime assembly is present, we add an explicit reference to WebView2.Core on Windows.
    -->
    <AgibuildWebView_WebView2PackageVersion>1.0.3719.77</AgibuildWebView_WebView2PackageVersion>
    <AgibuildFuloraTargetRuntimeIdentifier>$([System.String]::Copy('$(RuntimeIdentifier)').ToLowerInvariant())</AgibuildFuloraTargetRuntimeIdentifier>
    <AgibuildFuloraTargetRuntimeIdentifier Condition="'$(AgibuildFuloraTargetRuntimeIdentifier)' == '' and $([MSBuild]::IsOSPlatform(`windows`))">win-host</AgibuildFuloraTargetRuntimeIdentifier>
    <AgibuildFuloraTargetRuntimeIdentifier Condition="'$(AgibuildFuloraTargetRuntimeIdentifier)' == '' and $([MSBuild]::IsOSPlatform(`osx`))">osx-host</AgibuildFuloraTargetRuntimeIdentifier>
    <AgibuildFuloraTargetRuntimeIdentifier Condition="'$(AgibuildFuloraTargetRuntimeIdentifier)' == '' and $([MSBuild]::IsOSPlatform(`linux`))">linux-host</AgibuildFuloraTargetRuntimeIdentifier>
  </PropertyGroup>

  <ItemGroup Condition="$([System.String]::Copy('$(AgibuildFuloraTargetRuntimeIdentifier)').StartsWith('win'))">
    <Reference Include="Microsoft.Web.WebView2.Core">
      <HintPath>$(NuGetPackageRoot)microsoft.web.webview2\$(AgibuildWebView_WebView2PackageVersion)\lib_manual\netcoreapp3.0\Microsoft.Web.WebView2.Core.dll</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>

  <!--
    Ensure dynamically-loaded adapter assemblies aren't trimmed away.
    All managed adapters ship in lib/net10.0/ alongside the core DLLs.
    Module initializers register the correct adapter at runtime; the linker would
    otherwise remove "unused" adapters during publish trimming.
  -->
  <ItemGroup Condition="'$(PublishTrimmed)' == 'true'">
    <!-- Unified desktop platforms assembly: hosts Windows/WebView2, macOS/WKWebView, Linux/WebKitGTK adapters.
         Module initializer picks the right adapter for the current OS at runtime. -->
    <TrimmerRootAssembly Include="Agibuild.Fulora.Platforms"
                         Condition="$([System.String]::Copy('$(AgibuildFuloraTargetRuntimeIdentifier)').StartsWith('osx')) Or $([System.String]::Copy('$(AgibuildFuloraTargetRuntimeIdentifier)').StartsWith('win')) Or $([System.String]::Copy('$(AgibuildFuloraTargetRuntimeIdentifier)').StartsWith('linux'))" />
    <TrimmerRootAssembly Include="Agibuild.Fulora.Adapters.Android"
                         Condition="$([System.String]::Copy('$(AgibuildFuloraTargetRuntimeIdentifier)').StartsWith('android'))" />
    <TrimmerRootAssembly Include="Agibuild.Fulora.Adapters.iOS"
                         Condition="$([System.String]::Copy('$(AgibuildFuloraTargetRuntimeIdentifier)').StartsWith('ios')) Or $([System.String]::Copy('$(AgibuildFuloraTargetRuntimeIdentifier)').StartsWith('maccatalyst'))" />
  </ItemGroup>
</Project>
