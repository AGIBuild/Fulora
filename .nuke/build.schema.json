{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "definitions": {
    "Host": {
      "type": "string",
      "enum": [
        "AppVeyor",
        "AzurePipelines",
        "Bamboo",
        "Bitbucket",
        "Bitrise",
        "GitHubActions",
        "GitLab",
        "Jenkins",
        "Rider",
        "SpaceAutomation",
        "TeamCity",
        "Terminal",
        "TravisCI",
        "VisualStudio",
        "VSCode"
      ]
    },
    "ExecutableTarget": {
      "type": "string",
      "enum": [
        "AdoptionReadinessGovernance",
        "AutomationLaneReport",
        "BridgeDistributionGovernance",
        "Build",
        "BuildAll",
        "Ci",
        "CiMatrix",
        "CiPublish",
        "Clean",
        "ContinuousTransitionGateGovernance",
        "ContractAutomation",
        "Coverage",
        "DependencyVulnerabilityGovernance",
        "DistributionReadinessGovernance",
        "E2ETests",
        "Format",
        "IntegrationTests",
        "MutationTest",
        "NpmPublish",
        "NugetPackageTest",
        "OpenSpecStrictGovernance",
        "Pack",
        "PackageApp",
        "PackTemplate",
        "Publish",
        "PublishTemplate",
        "RefreshLockFiles",
        "ReleaseCloseoutSnapshot",
        "ReleaseOrchestrationGovernance",
        "Restore",
        "RuntimeAutomation",
        "RuntimeCriticalPathExecutionGovernance",
        "SampleTemplatePackageReferenceGovernance",
        "ShowVersion",
        "SolutionConsistencyGovernance",
        "Start",
        "StartAiChatApp",
        "StartAndroid",
        "StartIOS",
        "StartMinimalApp",
        "StartReactApp",
        "StartTodoApp",
        "StartVueApp",
        "TemplateE2E",
        "Test",
        "TypeScriptDeclarationGovernance",
        "UnitTests",
        "UpdateVersion",
        "ValidatePackage",
        "WarningGovernance",
        "WarningGovernanceSyntheticCheck"
      ]
    },
    "Verbosity": {
      "type": "string",
      "description": "",
      "enum": [
        "Verbose",
        "Normal",
        "Minimal",
        "Quiet"
      ]
    },
    "NukeBuild": {
      "properties": {
        "Continue": {
          "type": "boolean",
          "description": "Indicates to continue a previously failed build attempt"
        },
        "Help": {
          "type": "boolean",
          "description": "Shows the help text for this build assembly"
        },
        "Host": {
          "description": "Host for execution. Default is 'automatic'",
          "$ref": "#/definitions/Host"
        },
        "NoLogo": {
          "type": "boolean",
          "description": "Disables displaying the NUKE logo"
        },
        "Partition": {
          "type": "string",
          "description": "Partition to use on CI"
        },
        "Plan": {
          "type": "boolean",
          "description": "Shows the execution plan (HTML)"
        },
        "Profile": {
          "type": "array",
          "description": "Defines the profiles to load",
          "items": {
            "type": "string"
          }
        },
        "Root": {
          "type": "string",
          "description": "Root directory during build execution"
        },
        "Skip": {
          "type": "array",
          "description": "List of targets to be skipped. Empty list skips all dependencies",
          "items": {
            "$ref": "#/definitions/ExecutableTarget"
          }
        },
        "Target": {
          "type": "array",
          "description": "List of targets to be invoked. Default is '{default_target}'",
          "items": {
            "$ref": "#/definitions/ExecutableTarget"
          }
        },
        "Verbosity": {
          "description": "Logging verbosity during build execution. Default is 'Normal'",
          "$ref": "#/definitions/Verbosity"
        }
      }
    }
  },
  "allOf": [
    {
      "properties": {
        "AndroidAvd": {
          "type": "string",
          "description": "Android AVD name for emulator. Default: auto-detect first available AVD"
        },
        "AndroidSdkRoot": {
          "type": "string",
          "description": "Android SDK root path. Default: ~/Library/Android/sdk (macOS) or ANDROID_HOME env var"
        },
        "BranchCoverageThreshold": {
          "type": "integer",
          "description": "Minimum branch coverage percentage (0-100). Default: 93",
          "format": "int32"
        },
        "Configuration": {
          "type": "string",
          "description": "Configuration (Debug / Release). Default: Release on CI, Debug locally"
        },
        "CoverageThreshold": {
          "type": "integer",
          "description": "Minimum line coverage percentage (0-100). Default: 96",
          "format": "int32"
        },
        "iOSSimulator": {
          "type": "string",
          "description": "iOS Simulator device name. Default: auto-detect first available iPhone simulator"
        },
        "NpmToken": {
          "type": "string",
          "description": "npm auth token for @agibuild/bridge publication",
          "default": "Secrets must be entered via 'nuke :secrets [profile]'"
        },
        "NuGetApiKey": {
          "type": "string",
          "description": "NuGet API key for publish",
          "default": "Secrets must be entered via 'nuke :secrets [profile]'"
        },
        "NuGetSource": {
          "type": "string",
          "description": "NuGet source URL for publish. Default: https://api.nuget.org/v3/index.json"
        },
        "PackageAppVersion": {
          "type": "string",
          "description": "Application version for packaging"
        },
        "PackageOutput": {
          "type": "string",
          "description": "Output directory for packaged app"
        },
        "PackageProject": {
          "type": "string",
          "description": "Project to package (path to .csproj)"
        },
        "PackageRuntime": {
          "type": "string",
          "description": "Target runtime identifier (e.g., win-x64, osx-arm64)"
        },
        "UpdateVersionTo": {
          "type": "string",
          "description": "Target version to set (X.Y.Z format). If omitted, patch is auto-incremented"
        },
        "VersionSuffix": {
          "type": "string",
          "description": "Version suffix for pack/publish targets (e.g., ci.42, rc.1). Empty = stable release"
        },
        "WarningGovernanceInput": {
          "type": "string",
          "description": "Optional warning scanner input file path. If set, scanner consumes this file instead of live build output"
        }
      }
    },
    {
      "$ref": "#/definitions/NukeBuild"
    }
  ]
}
